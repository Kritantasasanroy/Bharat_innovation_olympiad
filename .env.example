# ── Database (Neon.tech free tier recommended) ──
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/olympiad?sslmode=require

# ── JWT ── (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex

# ── Admin credentials ──
ADMIN_EMAIL=admin@bharatolympiad.in
ADMIN_PASSWORD=replace-with-strong-password

# ── CORS origins (your Vercel URLs) ──
FRONTEND_URL=https://your-student-app.vercel.app
ADMIN_FRONTEND_URL=https://your-admin-app.vercel.app
ALLOWED_ORIGINS=https://your-student-app.vercel.app,https://your-admin-app.vercel.app

# ── Proctor service (unused in current inline mode, keep for future) ──
PROCTOR_API_KEY=replace-with-random-key

# ── Server ──
PORT=4000

# ── Frontend build vars (used in docker-compose for local dev) ──
NEXT_PUBLIC_API_URL=https://api.bharatolympiad.in
NEXT_PUBLIC_WS_URL=wss://api.bharatolympiad.in
