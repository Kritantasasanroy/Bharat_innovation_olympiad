# Database
DATABASE_URL=postgresql://olympiad_user:olympiad_dev_pass@localhost:5432/olympiad

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Redis
REDIS_URL=redis://localhost:6379

# Proctor Service (Meazure Learning / ProctorU bridge)
# The Python proctor-service must be running at this URL
PROCTOR_SERVICE_URL=http://localhost:5000
# Shared secret — must match PROCTOR_API_KEY in proctor-service/.env
PROCTOR_API_KEY=dev-proctor-key

# Frontend
FRONTEND_URL=http://localhost:3000

# App
PORT=4000
APP_URL=https://exam.bharatolympiad.in

# Razorpay (use rzp_test_... keys for development)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# AWS S3 (for question media, proctor snapshots, invoices, admit cards)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bio-olympiad-prod
