# ── Internal shared key (NestJS backend presents this when calling this service) ──
PROCTOR_API_KEY=dev-proctor-key

# ── Meazure Learning / ProctorU credentials ──
# Obtain from: https://dashboard.meazurelearning.com → Settings → API
MEAZURE_API_KEY=
MEAZURE_BASE_URL=https://api.meazurelearning.com/api/v2

# Webhook secret — set in Meazure dashboard → Settings → Webhooks → Add Endpoint
# This service verifies X-Meazure-Signature: sha256=<hmac> on every incoming webhook.
MEAZURE_WEBHOOK_SECRET=

# ── NestJS backend (where this service forwards validated webhook events) ──
NESTJS_CALLBACK_URL=http://localhost:4000
NESTJS_CALLBACK_KEY=dev-proctor-key
